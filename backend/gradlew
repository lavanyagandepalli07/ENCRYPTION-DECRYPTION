#!/usr/bin/env bash

# Gradle wrapper script for Unix/Linux/Mac

# Get the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Use the local Gradle distribution if available
if [ -d "$SCRIPT_DIR/gradle-8.10.2/bin" ]; then
    exec "$SCRIPT_DIR/gradle-8.10.2/bin/gradle" "$@"
else
    # Fall back to system gradle
    exec gradle "$@"
fi
